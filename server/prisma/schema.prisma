generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jobs         Job[]
}

model AppSetting {
  id                       String   @id
  enrollmentTokenEncrypted String
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Server {
  id                   String           @id @default(cuid())
  name                 String
  environment          String
  notes                String?
  isActive             Boolean          @default(true)
  agentId              String?          @unique
  agentSecretEncrypted String?
  hostname             String?
  sshHost              String?
  sshPort              Int              @default(22)
  osName               String?
  osVersion            String?
  agentVersion         String?
  lastSeenAt           DateTime?
  lastReportAt         DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  snapshots            ServerSnapshot[]
  jobs                 Job[]

  @@index([createdAt])
  @@index([lastSeenAt])
  @@index([lastReportAt])
}

model ServerSnapshot {
  id              String   @id @default(cuid())
  serverId        String
  reachable       Boolean
  upgradableCount Int
  securityCount   Int
  rebootRequired  Boolean
  lastCheckAt     DateTime
  outputPreview   String
  rawSummaryJson  String
  createdAt       DateTime @default(now())
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, lastCheckAt])
}

model Job {
  id                String   @id @default(cuid())
  serverId          String
  type              String
  status            String
  claimedAt         DateTime?
  startedAt         DateTime?
  finishedAt        DateTime?
  outputPreview     String?
  errorMessage      String?
  triggeredByUserId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  server            Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  triggeredByUser   User     @relation(fields: [triggeredByUserId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
  @@index([status, createdAt])
  @@index([serverId, status, createdAt])
}
