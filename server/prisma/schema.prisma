generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jobs         Job[]
}

model Server {
  id                  String           @id @default(cuid())
  name                String
  environment         String
  agentBaseUrl        String
  agentTokenEncrypted String
  notes               String?
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  snapshots           ServerSnapshot[]
  jobs                Job[]
}

model ServerSnapshot {
  id              String   @id @default(cuid())
  serverId        String
  reachable       Boolean
  upgradableCount Int
  securityCount   Int
  rebootRequired  Boolean
  lastCheckAt     DateTime
  rawSummaryJson  String
  createdAt       DateTime @default(now())
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, lastCheckAt])
}

model Job {
  id                String   @id @default(cuid())
  serverId          String
  type              String
  status            String
  startedAt         DateTime?
  finishedAt        DateTime?
  outputPreview     String?
  errorMessage      String?
  triggeredByUserId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  server            Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  triggeredByUser   User     @relation(fields: [triggeredByUserId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
}
